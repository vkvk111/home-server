// --------------------  db stuff below --------------------
const sqlite3 = require('sqlite3').verbose();
const db = new sqlite3.Database('db.sqlite');

// Create table if it doesn't exist
db.serialize(() => {
    db.run(`CREATE TABLE IF NOT EXISTS posts (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        deviceId TEXT,
        sensorId INTEGER,
        value REAL,
        timestamp INTEGER
    )`);
});


