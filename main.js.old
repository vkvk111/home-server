// ----------------------------  websocket stuff below --------------------
const WebSocket = require('ws');
let ws = null; // Declare ws variable globally
let connectionInterval = null; // Variable to hold the interval for pinging the WebSocket server
connectWebSocket(); // Call the function to establish the WebSocket connection (ws will be used globally so this has to be called here)
function connectWebSocket() {
    
    ws = new WebSocket('wss://kybetube.com:443');

    ws.on('open', function open() {
    // ...removed print...
        // send a message to set the device ID or any initial setup
        if (ws.readyState === WebSocket.OPEN) {
            ws.send(`set_gateway_id;${gatewayId}`); // Send the gateway ID to the server
        }else {
            // ...removed print...
        }
        if (connectionInterval) {
            clearInterval(connectionInterval); // Clear any existing ping interval before setting a new one
            connectionInterval = null; // Reset the interval variable
        }
        connectionInterval = setInterval(() => {
            if (ws.readyState === WebSocket.OPEN) {
                ws.ping(); // Send a ping to keep the connection alive
                // ...removed print...
            } else {
                // ...removed print...
                // Attempt to reconnect if the WebSocket is not open
                ws.terminate(); // Close the current connection
                ws = null; // Reset the ws variable
                
                connectWebSocket();
            }
        }, 120 * 1000); // every 120 seconds
    });

    ws.on('message', async (message) => {
        const parts = message.toString().split(';');
        const what = parts[0];

        if (what === 'execute') {
            const senderId = parts[1]; // Who requested the command
            const command = parts.slice(2).join(';');

            // ...removed print...

            // Execute the command and send output back
            exec(command, (error, stdout, stderr) => {
                const output = error ? `ERROR: ${error.message}` : stdout || stderr;
                ws.send(`output;${senderId};${output}`);
            });
            
        } else if (what === "reboot") {
            rebootDevice();
        } else if (what === "get_status_plug") {
            const deviceId = parts[1];
            const messageId = parts[2];

            //get plug status
            const plugStatus = await getPlugStatus(deviceId);
            // ...removed print...

            // Response with plug status
            const response = `output;0;${plugStatus};${messageId}`;
            ws.send(response);
        } else if (what === "set_status_plug") {
            const deviceId = parts[1];
            const status = parts[2];
            
            // Set plug status
            setPlugStatus(deviceId, status);
        }
    });

    ws.on('close', function close() {
    // ...removed print...
        //ws = new WebSocket('wss://kybetube.com:443'); // Reconnect to the WebSocket server ////NOT WORKING I THINK THIS NEEDS A BETTER SOLUTION
    });

    ws.on('error', function error(err) {
    // ...removed print...
    });
}








