function processPlugMessage(topic, message) {
    // Example processing function
    // ...removed print...
    // Add your processing logic here
    const topicParts = topic.split('/');
    //string is "plug[id]/xxx/xxx" without the []
    const plugId = topicParts[0].replace('plug', '');
    const topicType = topicParts[1]; // e.g., 'status', 'command', etc.
    const messageContent = message.toString();
    //timestamp in seconds
    const timestamp = Math.floor(Date.now() / 1000);

    // Here you can implement your logic based on the plugId and topicType
    if (topicType === 'voltage') {
        const sensorId = 1; //voltage is always sensor 1
        const sensorValue = parseFloat(messageContent); // Assuming the message is a numeric value
    // ...removed print...
        // Save to database
        db.run(
            `INSERT INTO posts (deviceId, sensorId, value, timestamp) VALUES (?, ?, ?, ?)`,
            [plugId, sensorId, sensorValue, timestamp],
            (err) => {
                if (err) console.error('Error inserting post:', err);
            }
        );

    }
    else if (topicType === 'current') {
        const sensorId = 2; //current is always sensor 2
        const sensorValue = parseFloat(messageContent); // Assuming the message is a numeric value
    // ...removed print...
        // Save to database
        db.run(
            `INSERT INTO posts (deviceId, sensorId, value, timestamp) VALUES (?, ?, ?, ?)`,
            [plugId, sensorId, sensorValue, timestamp],
            (err) => {
                if (err) console.error('Error inserting post:', err);
            }
        );
    }
    else if (topicType === 'energycounter') {
        const sensorId = 3; //energycounter is always sensor 3
        const sensorValue = parseFloat(messageContent); // Assuming the message is a numeric value
        // Save to database
        db.run(
            `INSERT INTO posts (deviceId, sensorId, value, timestamp) VALUES (?, ?, ?, ?)`,
            [plugId, sensorId, sensorValue, timestamp],
            (err) => {
                if (err) console.error('Error inserting post:', err);
            }
        );
    }
    else if (topicType === 'power') {
        const sensorId = 4; //power is always sensor 3
        const sensorValue = parseFloat(messageContent); // Assuming the message is a numeric value
        // Save to database
        db.run(
            `INSERT INTO posts (deviceId, sensorId, value, timestamp) VALUES (?, ?, ?, ?)`,
            [plugId, sensorId, sensorValue, timestamp],
            (err) => {
                if (err) console.error('Error inserting post:', err);
            }
        );
    } 
    else if (topicType === 'power_factor') {
        const sensorId = 5; //power_factor is always sensor 5
        const sensorValue = parseFloat(messageContent); // Assuming the message is a numeric value
        // Save to database
        db.run(
            `INSERT INTO posts (deviceId, sensorId, value, timestamp) VALUES (?, ?, ?, ?)`,
            [plugId, sensorId, sensorValue, timestamp],
            (err) => {
                if (err) console.error('Error inserting post:', err);
            }
        );
    } else if (topicType === 'status') {
        //console.log(`Status message from plug ${plugId}: ${messageContent}`);
    }

}


async function sendData(data) {
    return new Promise((resolve, reject) => {
        fetch(serverUrl + '/sensordata', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(res => res.status)
        .then(status => {
            if (status == 200) {
                //console.log('Data sent successfully');
                resolve(status);
            } else {
                reject(status);
                console.error('Failed to send data, status code:', status);
            }
        })
    })
    .catch(error => {
        console.error('Error sending data:', error);
        reject(error);
    });
}


async function pingDevice(deviceId) {

    return new Promise((resolve, reject) => {
        fetch(serverUrl + "/deviceping", {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: deviceId })
        })
        .then(response => {
            console.log(`Pinged device ${deviceId}, status code: ${response.status}`);
            if (response.status == 200) {
                resolve(response.status);
            } else {
                reject(`Failed to ping device ${deviceId}, status code: ${response.status}`);
            }
        })
        .catch(error => {
            console.error(`Error pinging device ${deviceId}:`, error);
            reject(error);
        });
    });
}

function gatewayPing(deviceIds) {
    return new Promise(async (resolve, reject) => {
        
        console.log("deviceIds: " + deviceIds);
        try {
            const response = await fetch(serverUrl + "/gatewayping", {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ gatewayId: gatewayId, connectedDevices: deviceIds })
            });
            if (response.status == 200) {
                console.log('Gateway pinged successfully');
                resolve(response.status);
            } else {
                console.error('Failed to ping gateway, status code:', response.status);
                resolve(response.status); // Resolve with status code even if not 200
            }
        } catch (error) {
            console.error('Error pinging gateway:', error);
            resolve(-1); // Resolve with -1 to indicate an error
        }
    });
}


function getAllPosts() {
    return new Promise((resolve, reject) => {
        db.all(`SELECT * FROM posts`, (err, rows) => {
            if (err) reject(err);
            else resolve(rows);
        });
    });
}

//send loop
// loop every x minutes to send data to the server, but for now just log "sent data to server" and delete the data from the database
async function sendLoop() {
    const posts = await getAllPosts();
    const deviceIds = [...new Set(posts.map(post => post.deviceId))];

    const ping = await gatewayPing(deviceIds);

    if (ping != 200) {
        console.error('Failed to ping gateway, aborting data send. Data length:' + posts.length);
        setTimeout(sendLoop, 60 * 1000); // Wait and try again
        return;
    }

    if (posts.length > 0 && posts.length < 500) {
        console.log("Sending data to server, posts length: " + posts.length);
        const dataToSend = posts.map(post => ({
            deviceId: post.deviceId,
            sensorId: post.sensorId,
            value: post.value,
            timestamp: post.timestamp
        }));
        try {
            const status = await sendData(dataToSend);
            if (status == 200) {
                console.log('Data sent successfully');
                db.run(`DELETE FROM posts`, (err) => {
                    if (err) console.error('Error deleting posts:', err);
                });
            } else {
                console.error('Failed to send data, status code:', status);
            }
        } catch (error) {
            console.error('Error sending data:', error);
        }
    } else if (posts.length >= 500) {
        console.log("Sending data in batches, posts length: " + posts.length);
        
        let remaining = posts;
        while (remaining.length > 0) {
            const batch = remaining.slice(0, 500);
            try {
                const status = await sendData(batch);
                if (status == 200) {
                    const ids = batch.map(post => post.id);
                    const placeholders = ids.map(() => '?').join(',');
                    db.run(`DELETE FROM posts WHERE id IN (${placeholders})`, ids, (err) => {
                        if (err) console.error('Error deleting batch:', err);
                    });
                } else {
                    break;
                }
            } catch (error) {
                break;
            }
            remaining = await getAllPosts();
        }
    } else {
        console.log('No data to send');
    }
    console.log('Data send loop completed, waiting for next run...');
    setTimeout(sendLoop, 60 * 1000); // Schedule next run after completion
}

// Start the loop

console.log('Starting send loop...');
sendLoop();



