async function getPlugStatus(id) {
    return new Promise((resolve, reject) => {
        const statusTopic = `cmnd/plug${id}/Status`;
        const responseTopic = `stat/plug${id}/STATUS`;

        // Handler for the response
        function handleMessage(topic, message) {
            if (topic == responseTopic) {
                client.removeListener('message', handleMessage);
                resolve(message.toString());
            }
        }

        // Listen for the response
        client.on('message', handleMessage);

        // Publish the status request
        client.publish(statusTopic, '0', { qos: 1 }, (err) => {
            if (err) {
                client.removeListener('message', handleMessage);
                reject(`Failed to request status for device ${id}: ${err}`);
            }
        });

        // Timeout in case no response comes
        setTimeout(() => {
            client.removeListener('message', handleMessage);
            reject('Timeout waiting for plug status');
        }, 5000); // 5 seconds timeout
    });
}

async function setPlugStatusAwait(id, status) {
    return new Promise((resolve, reject) => {
        const commandTopic = `cmnd/plug${id}/Power`;
        client.publish(commandTopic, status, { qos: 1 }, (err) => {
            if (err) {
                reject(`Failed to set status for device ${id}: ${err}`);
            } else {
                resolve(`Status set for device ${id}`);
            }
        });
    });
}

