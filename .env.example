# Server
PORT=3000
HOST=0.0.0.0

# Python binary to use for GPIO scripts.
# After running scripts/setup/03-python-deps.sh this is auto-set to the venv.
PYTHON_BIN=python3

# ── Network ───────────────────────────────────────────────────────────────────
# Wireless interface (almost always wlan0 on the Pi)
WIFI_IFACE=wlan0

# Primary (home) WiFi — checked on boot for updates
WIFI_SSID=uGotHacked:)
WIFI_PASS=xx7usavf7szhx

# Access Point that the Pi broadcasts after the update check
AP_SSID=lever
AP_PASS=xx7usavf7szhx

# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_BROKER=mqtt://localhost:1883
MQTT_USER=kybe
MQTT_PASS=88888888
